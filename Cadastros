    }

    private static void listarAtividades(Connection conn) throws SQLException {
        imprimirTabelaSimples(conn, "SELECT idAtividadeACC, Titulo FROM AtividadeACC");
    }


    private static void imprimirTabelaSimples(Connection conn, String sql) throws SQLException {
        try (Statement stmt = conn.createStatement();
             ResultSet rs = stmt.executeQuery(sql)) {
            int colCount = rs.getMetaData().getColumnCount();
            System.out.println("--- Registros disponíveis ---");
            while (rs.next()) {
                StringBuilder linha = new StringBuilder();
                for (int i = 1; i <= colCount; i++) {
                    linha.append(rs.getMetaData().getColumnName(i)).append("=").append(rs.getString(i)).append("  ");
                }
                System.out.println(linha);
            }
            System.out.println("------------------------------");
        }
    }
}
