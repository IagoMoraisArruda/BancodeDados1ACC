    public static void cadastrarCurso(Connection conn, Scanner sc) throws SQLException {
        System.out.print("Nome do curso: ");
        String nome = sc.nextLine();
        System.out.print("Carga horária exigida de ACC (em horas): ");
        int cargaExigida = Integer.parseInt(sc.nextLine());

        String sql = "INSERT INTO Curso (NomeCurso, CargaHorariaExigida) VALUES (?, ?)";
        try (PreparedStatement stmt = conn.prepareStatement(sql)) {
            stmt.setString(1, nome);
            stmt.setInt(2, cargaExigida);
            stmt.executeUpdate();
            System.out.println("Curso cadastrado com sucesso!");
        }
    }

