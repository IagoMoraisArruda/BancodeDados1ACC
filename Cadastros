    public static void cadastrarAtividadeAcc(Connection conn, Scanner sc) throws SQLException {
        listarAlunos(conn);
        System.out.print("ID do aluno: ");
        int idAluno = Integer.parseInt(sc.nextLine());
        listarTiposAcc(conn);
        System.out.print("ID do tipo de ACC: ");
        int idTipoAcc = Integer.parseInt(sc.nextLine());
        listarPeriodos(conn);
        System.out.print("ID do período letivo: ");
        int idPeriodo = Integer.parseInt(sc.nextLine());
        System.out.print("Título da atividade: ");
        String titulo = sc.nextLine();
        System.out.print("Descrição: ");
        String descricao = sc.nextLine();
        System.out.print("Data de realização (AAAA-MM-DD): ");
        String data = sc.nextLine();
        System.out.print("Carga horária (em horas): ");
        double cargaHoraria = Double.parseDouble(sc.nextLine());
        System.out.print("Pontos solicitados: ");
        double pontosSolicitados = Double.parseDouble(sc.nextLine());

        String sql = "INSERT INTO AtividadeACC " +
                "(Aluno_idAluno, TipoACC_idTipoACC, PeriodoLetivo_idPeriodo, Titulo, Descricao, DataRealizacao, CargaHoraria, PontosSolicitados) " +
                "VALUES (?, ?, ?, ?, ?, ?, ?, ?)";
        try (PreparedStatement stmt = conn.prepareStatement(sql)) {
            stmt.setInt(1, idAluno);
            stmt.setInt(2, idTipoAcc);
            stmt.setInt(3, idPeriodo);
            stmt.setString(4, titulo);
            stmt.setString(5, descricao);
            stmt.setDate(6, java.sql.Date.valueOf(data));
            stmt.setDouble(7, cargaHoraria);
            stmt.setDouble(8, pontosSolicitados);
            stmt.executeUpdate();
            System.out.println("Atividade cadastrada com sucesso!");
        }
    }

